{
  "description": "Agent Recall memory system hooks for Gemini CLI",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$AGENT_RECALL_ROOT/plugin/scripts/bun-runner.js\" \"$AGENT_RECALL_ROOT/plugin/scripts/worker-service.cjs\" start",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "node \"$AGENT_RECALL_ROOT/plugin/scripts/bun-runner.js\" \"$AGENT_RECALL_ROOT/plugin/scripts/worker-service.cjs\" hook gemini-cli context",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$AGENT_RECALL_ROOT/plugin/scripts/bun-runner.js\" \"$AGENT_RECALL_ROOT/plugin/scripts/worker-service.cjs\" hook gemini-cli session-init",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$AGENT_RECALL_ROOT/plugin/scripts/bun-runner.js\" \"$AGENT_RECALL_ROOT/plugin/scripts/worker-service.cjs\" hook gemini-cli observation",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$AGENT_RECALL_ROOT/plugin/scripts/bun-runner.js\" \"$AGENT_RECALL_ROOT/plugin/scripts/worker-service.cjs\" hook gemini-cli summarize",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$AGENT_RECALL_ROOT/plugin/scripts/bun-runner.js\" \"$AGENT_RECALL_ROOT/plugin/scripts/worker-service.cjs\" hook gemini-cli session-complete",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
