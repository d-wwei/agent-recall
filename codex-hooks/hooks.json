{
  "description": "Agent Recall memory system hooks for Codex CLI",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$AGENT_RECALL_ROOT/scripts/bun-runner.js\" \"$AGENT_RECALL_ROOT/scripts/worker-service.cjs\" start",
            "statusMessage": "Starting Agent Recall",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "node \"$AGENT_RECALL_ROOT/scripts/bun-runner.js\" \"$AGENT_RECALL_ROOT/scripts/worker-service.cjs\" hook codex context",
            "statusMessage": "Loading memory context",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$AGENT_RECALL_ROOT/scripts/bun-runner.js\" \"$AGENT_RECALL_ROOT/scripts/worker-service.cjs\" hook codex session-init",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$AGENT_RECALL_ROOT/scripts/bun-runner.js\" \"$AGENT_RECALL_ROOT/scripts/worker-service.cjs\" hook codex observation",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$AGENT_RECALL_ROOT/scripts/bun-runner.js\" \"$AGENT_RECALL_ROOT/scripts/worker-service.cjs\" hook codex summarize",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
